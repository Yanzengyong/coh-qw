# COH Cigars Bundled Clearance monitor
TARGET_URL=https://cohcigars.com/cigars-bundle-clearance
COH_COUNTRY=China
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_MS=60000
STATE_FILE=data/coh-clearance-state.json
FIRST_RUN_NOTIFY=false
INCLUDE_PRICE_CHANGES=true
MAX_NOTIFY_ITEMS=20

# WeChat push provider:
# pushplus, serverchan, wecom, webhook, or console
PUSH_PROVIDER=wecom

# Enterprise WeChat group robot webhook.
# Example: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx
WECOM_BOT_WEBHOOK=

# PushPlus: https://www.pushplus.plus/
PUSHPLUS_TOKEN=
PUSHPLUS_TOPIC=

# ServerChan: https://sct.ftqq.com/
SERVERCHAN_SENDKEY=

# Generic webhook. Receives JSON: { "title": "...", "content": "..." }
WEBHOOK_URL=
